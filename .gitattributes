# Normalize line endings for source/docs in this repository.
* text=auto

*.cs text eol=crlf
*.csproj text eol=crlf
*.wixproj text eol=crlf
*.wxs text eol=crlf
*.config text eol=crlf
*.xml text eol=crlf
*.json text eol=crlf
*.ps1 text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf

# Binary artifacts
*.png binary
*.ico binary
*.dll binary
*.pdb binary
*.msi binary
